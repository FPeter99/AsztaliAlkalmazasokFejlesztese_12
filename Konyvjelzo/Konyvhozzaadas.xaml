<Window x:Class="Konyvjelzo.Konyvhozzaadas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Konyvjelzo"
        mc:Ignorable="d"
        Title="Konyvhozzaadas" Height="450" Width="800">
    <Grid Width="350" HorizontalAlignment="Left">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="2" LastChildFill="False" Margin="30,5">

            <TextBlock FontSize="20" DockPanel.Dock="Left" VerticalAlignment="Center">
                Szerző:
            </TextBlock>

            <TextBox FontSize="20" Name="szerzoMezo" Width="220" Height="30" DockPanel.Dock="Right"/>

        </DockPanel>

        <DockPanel Grid.Row="1" LastChildFill="False" Margin="30,5">

            <TextBlock FontSize="20" DockPanel.Dock="Left" VerticalAlignment="Center">
                Cím:
            </TextBlock>

            <TextBox  FontSize="20" Name="nevMezo" Width="220" Height="30" DockPanel.Dock="Right"/>

        </DockPanel>

        <WrapPanel Grid.Row="3" HorizontalAlignment="Center">
            <WrapPanel>
                <Button Padding="20,0,20,0" Margin="10" Click="bt_Mentes">
                    Mentés
                </Button>
            </WrapPanel>
            <WrapPanel>
                <Button Padding="20,0,20,0" Margin="10" Click="bt_Megsem">
                    Mégsem
                </Button>
            </WrapPanel>
        </WrapPanel>



    </Grid>
</Window>
