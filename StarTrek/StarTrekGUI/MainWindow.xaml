<Window x:Class="StarTrekGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StarTrekGUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="250" Width="500">
    
    <StackPanel VerticalAlignment="Top">

        <TextBlock Margin="55,20,0,0" Text="Kérem, válasszon szerepet:"/>

        <ComboBox x:Name="cb_Szerep" Width="400" HorizontalAlignment="Left" Margin="50,5,0,0" SelectionChanged="cb_Szerep_SelectionChanged"/>

        <TextBlock Margin="55,20,0,0" Text="Kérem, válasszon űrhjót:"/>

        <ComboBox x:Name="cb_Urhajo" Width="400" HorizontalAlignment="Left" Margin="50,5,0,20" SelectionChanged="cb_Urhajo_SelectionChanged"/>

        <Grid Height="60" x:Name="grid_Info" Visibility="Hidden">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1*" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Hajó osztálya:" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Hajót üzemeltető faj:" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="tb_Osztaly" IsReadOnly="True" Margin="0,2,50,2"></TextBox>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="tb_Faj" IsReadOnly="True" Margin="0,2,50,2"></TextBox>
        </Grid>
        
    </StackPanel>



</Window>
