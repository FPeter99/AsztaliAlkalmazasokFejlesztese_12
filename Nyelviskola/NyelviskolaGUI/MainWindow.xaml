<Window x:Class="NyelviskolaGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NyelviskolaGUI"
        mc:Ignorable="d"
        Title="Nyelvtanárok adatai" Height="450" Width="800">
    <DockPanel Margin="20">
        <Label Content="Kérem válaszon nyelvet: " DockPanel.Dock="Top"></Label>
        <ComboBox x:Name="cb_nyelv" DockPanel.Dock="Top" SelectionChanged="cb_nyelv_SelectionChanged"></ComboBox>
        <Label Content="Kérem válaszon tanárt: " DockPanel.Dock="Top" Margin="0,20,0,0"></Label>
        <ComboBox x:Name="cb_tanar" DockPanel.Dock="Top" SelectionChanged="cb_tanar_SelectionChanged" IsEnabled="False"></ComboBox>
        <Grid x:Name="gr_adatok" Visibility="Hidden">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition Height="auto" MinHeight="20"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="auto" MinHeight="20"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="auto" MinHeight="20"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="auto" MinHeight="20"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="auto" MinHeight="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="Telefon:" Grid.Row="1" Grid.Column="0"/>
            <TextBox IsReadOnly="True" x:Name="tb_telefon" Grid.Row="1" Grid.Column="1"/>
            <Label Content="Email:" Grid.Row="3" Grid.Column="0"/>
            <TextBox IsReadOnly="True" x:Name="tb_email" Grid.Row="3" Grid.Column="1"/>
            <Label Content="Óradíj" Grid.Row="5" Grid.Column="0"/>
            <TextBox IsReadOnly="True" x:Name="tb_oradij" Grid.Row="5" Grid.Column="1"/>
            <Label Content="Ft" Grid.Row="5" Grid.Column="2"/>
            <Label Content="Online óra:" Grid.Row="7" Grid.Column="0"/>
            <CheckBox IsEnabled="False" x:Name="chb_onlineOra" Grid.Row="7" Grid.Column="1"/>
        </Grid>

    </DockPanel>
</Window>
