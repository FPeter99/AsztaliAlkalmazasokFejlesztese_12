<Window x:Class="CsevegesGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CsevegesGUI"
        mc:Ignorable="d"
        Title="Csevegés GUI" Height="600" Width="500">
    <StackPanel Orientation="Vertical" VerticalAlignment="Top">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="45"/>
                <RowDefinition Height="45"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="1" Grid.Column="0" Margin="25,0,0,0" VerticalAlignment="Center" FontSize="20">
                Kezdeményező
            </TextBlock>
            <TextBlock Grid.Row="2" Grid.Column="0" Margin="25,0,0,0" VerticalAlignment="Center" FontSize="20">
                Fogadó (partner)
            </TextBlock>
            <ComboBox SelectionChanged="cb_SelectionChanged" Grid.Row="1" Grid.Column="1" Margin="8" Name="cb_kezdemenyezo" FontSize="20">

            </ComboBox>
            <ComboBox SelectionChanged="cb_SelectionChanged" Grid.Row="2" Grid.Column="1" Margin="8" Name="cb_fogado" FontSize="20">

            </ComboBox>
        </Grid>

        <TextBlock Margin="25,30,0,0" FontSize="20">
            Csevegések
        </TextBlock>

        <ListBox Margin="40,5,40,40" Height="352" Name="lb">
            
        </ListBox>
    </StackPanel>
</Window>
